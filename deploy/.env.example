# Production environment for docker-compose.prod.yml.
# Copy to `.env` next to docker-compose.prod.yml on the server and fill in.
# Never commit the real `.env`.

# ── Database (AWS RDS PostgreSQL) ────────────────────────────────────────────
# Use the RDS endpoint. sslmode=require because RDS enforces TLS.
DATABASE_URL=jdbc:postgresql://YOUR-RDS-ENDPOINT.rds.amazonaws.com:5432/archsim?sslmode=require
DATABASE_USER=archsim
DATABASE_PASSWORD=your-rds-password

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED under the prod profile — the app refuses to start with a weak/default
# secret. Generate with:  openssl rand -base64 48
ARCHSIM_TOKEN_SECRET=paste-a-long-random-value-here

# Your public origin. With the single-origin setup this only matters if you also
# call the API cross-origin; harmless to keep correct.
ARCHSIM_ALLOWED_ORIGINS=https://arch-sim.dev
