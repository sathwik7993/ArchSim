# ArchSim — environment configuration
#
# Copy to `.env` and fill in real values for production. Never commit `.env`.
# Everything here has a safe local default in application.yml, so for local dev
# you can run without any of these set. In production, set them all.

# ── Security (REQUIRED in production) ────────────────────────────────────────
# HMAC signing secret for access tokens. Generate a strong random value — the
# app REFUSES TO START under SPRING_PROFILES_ACTIVE=prod if this is left at the
# default or is shorter than 32 characters.
#   generate with:  openssl rand -base64 48
ARCHSIM_TOKEN_SECRET=change-me-to-a-long-random-value

# Comma-separated list of browser origins allowed to call the API (CORS).
# Set this to your real frontend origin(s), e.g. https://archsim.example.com
ARCHSIM_ALLOWED_ORIGINS=http://localhost:5173

# Auth rate limit (per client IP): max login/register requests per window.
ARCHSIM_AUTH_RATE_LIMIT=20
ARCHSIM_AUTH_RATE_WINDOW=60

# ── Database (REQUIRED in production) ────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/archsim
DATABASE_USER=archsim
DATABASE_PASSWORD=change-me

# ── Runtime ──────────────────────────────────────────────────────────────────
# Activate production guards (strong-secret enforcement, etc.).
SPRING_PROFILES_ACTIVE=prod
PORT=8080

# ── TLS ──────────────────────────────────────────────────────────────────────
# TLS is terminated at your platform/reverse proxy (Render/Railway/Fly, or
# Caddy/Traefik/nginx in front of the container). The app trusts X-Forwarded-*
# (server.forward-headers-strategy=framework) so HSTS and redirects use https.
# No cert config is needed inside the app; terminate TLS at the edge.
